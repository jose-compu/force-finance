# Avalanche RPC (optional; public RPC is used if unset)
AVALANCHE_RPC_URL=https://avalanche-mainnet.infura.io/v3/YOUR_INFURA_KEY
INFURA_API_KEY=your_infura_project_id

# Fuji testnet RPC (optional)
FUJI_RPC_URL=https://api.avax-test.network/ext/bc/C/rpc

# Deployment wallet (optional; leave empty for read-only / local Hardhat accounts)
PRIVATE_KEY=

# Snowtrace contract verification (optional)
SNOWTRACE_API_KEY=

# Optional chain IDs (defaults in hardhat.config.js)
# AVALANCHE_CHAIN_ID=43114
# FUJI_CHAIN_ID=43113
# HARDHAT_CHAIN_ID=31337

# Test tooling
REPORT_GAS=true
